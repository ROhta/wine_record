{
  "printWidth": 1000,
  "tabWidth": 2,
  "useTabs": true,
  "semi": false,
  "singleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": false,
  "bracketSameLine": false,
  "arrowParens": "avoid",
  "requirePragma": false,
  "insertPragma": false,
  "proseWrap": "always",
  "htmlWhitespaceSensitivity": "css",
  "singleAttributePerLine": false,
  "embeddedLanguageFormatting": "auto",
  "objectWrap": "preserve",
  "experimentalOperatorPosition": "end",
  "endOfLine": "lf"
}
