# Upstash Vector（埋め込みモデル BAAI/bge-m3 でインデックス作成済みのもの）
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# オブジェクトストレージ（Cloudflare R2 を既定とする。ラベル画像の保存先）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# 保存後に参照する公開ベース URL（例: https://images.example.com）
R2_PUBLIC_BASE_URL=

# MCP サーバー（Streamable HTTP）が listen するポート
PORT=3000
