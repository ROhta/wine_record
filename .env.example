# ── Upstash Vector（必須）──────────────────────────────────────
# 埋め込みモデル BAAI/bge-m3（dense・1024次元・COSINE）でインデックス作成済みのもの。
# Vercel の Upstash Vector 統合（Free プラン）から作成できる。詳細は
# specs/001-record-wine/research.md R1。
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ── 画像ストレージ（US3 用・任意）──────────────────────────────
# ラベル画像の永続化（US3）は確認ウィジェット（widget）の claude.ai リモート HTTP 対応待ちで
# 未着手のため、US1+US2 の稼働には不要。未設定でもサーバーは起動する。
# 未設定なら record_wine は imageUrl を受理しない（fail-closed）。
# 方針: R3 で Cloudflare R2 → Vercel Blob（private）へ変更済み。US3 実装時に変数名を見直す。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# 保存後に参照する公開ベース URL（例: https://images.example.com）
R2_PUBLIC_BASE_URL=

# ── サーバー ───────────────────────────────────────────────────
# MCP サーバー（Streamable HTTP）が listen するポート（既定 3000）
PORT=3000
